{
    "compilerOptions": {
        "outDir": "./types",
        "esModuleInterop": true,
        "allowJs": true,
        "declaration": false,
        "skipLibCheck": true,
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node",
        ],
        "typeRoots": [
            "../../node_modules/",
            "../../node_modules/@types"
        ]
    },
    "include": [
        "src",
        "types/*.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
